{
	"name": "next-template",
	"private": true,
	"version": "0.0.0",
	"scripts": {
		"deps-update": "ncu -u & npm i",
		"start": "next dev",
		"eslint": "next lint",
		"stylelint": "stylelint \"./**/*.{css,scss}\" --fix",
		"check": "npm run eslint && npm run stylelint",
		"prepare": "husky",
		"commit": "cz",
		"build": "next build",
		"prod": "npm run build & next start"
	},
	"config": {
		"commitizen": {
			"path": "./node_modules/cz-conventional-changelog"
		}
	},
	"dependencies": {
		"@reduxjs/toolkit": "2.7.0",
		"clsx": "2.1.1",
		"next": "15.3.1",
		"react": "19.1.0",
		"react-dom": "19.1.0",
		"react-redux": "9.2.0"
	},
	"devDependencies": {
		"@eslint/eslintrc": "3.3.1",
		"@svgr/webpack": "8.1.0",
		"@tailwindcss/postcss": "4.1.5",
		"@types/node": "22.15.12",
		"@types/react": "19.1.3",
		"@types/react-dom": "19.1.3",
		"commitizen": "4.3.1",
		"cz-conventional-changelog": "3.3.0",
		"eslint": "9.26.0",
		"eslint-config-next": "15.3.1",
		"eslint-config-prettier": "10.1.2",
		"husky": "9.1.7",
		"lint-staged": "15.5.2",
		"postcss": "8.5.3",
		"prettier-plugin-tailwindcss": "0.6.11",
		"sass": "1.87.0",
		"standard-version": "9.5.0",
		"stylelint": "16.19.1",
		"stylelint-config-standard": "38.0.0",
		"stylelint-config-standard-scss": "14.0.0",
		"stylelint-order": "7.0.0",
		"tailwindcss": "4.1.5",
		"typescript": "5.8.3"
	}
}
